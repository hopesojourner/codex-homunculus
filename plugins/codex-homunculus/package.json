{
  "name": "codex-homunculus",
  "version": "0.5.0",
  "description": "Codex-native Homunculus-style local memory and instincts.",
  "type": "module",
  "bin": {
    "codex-homunculus": "./scripts/homunculus.mjs",
    "codex-homunculus-helper": "./scripts/homunculus-helper.mjs"
  },
  "files": [
    ".codex-plugin/",
    "configs/",
    "docs/",
    "production/",
    "scripts/",
    "skills/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node --check scripts/homunculus.mjs && node --check scripts/smoke-test.mjs",
    "test": "node scripts/smoke-test.mjs",
    "ci": "npm run check && npm test && npm run validate-state && npm run pack:verify && npm run helper:health",
    "doctor": "node scripts/homunculus.mjs doctor",
    "helper:health": "node scripts/homunculus-helper.mjs health",
    "helper:maintenance": "node scripts/homunculus-helper.mjs maintenance",
    "validate-state": "node scripts/homunculus.mjs init && node scripts/homunculus.mjs validate",
    "pack:verify": "npm pack --dry-run"
  },
  "keywords": [
    "codex",
    "homunculus",
    "memory",
    "skills",
    "instincts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopesojourner/codex-homunculus.git",
    "directory": "plugins/codex-homunculus"
  },
  "homepage": "https://github.com/hopesojourner/codex-homunculus/tree/main/plugins/codex-homunculus",
  "bugs": {
    "url": "https://github.com/hopesojourner/codex-homunculus/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
